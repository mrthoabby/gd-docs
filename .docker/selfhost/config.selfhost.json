{
  "$schema": "https://github.com/toeverything/affine/releases/latest/download/config.schema.json",

  "server": {
    "name": "GD docs Server"
  },

  "auth": {
    "allowSignup": true,
    "allowSignupForOauth": true,
    "requireEmailVerification": false,
    "requireEmailDomainVerification": false,
    "passwordRequirements": {
      "min": 8,
      "max": 128
    },
    "session.ttl": 2592000,
    "session.ttr": 604800
  },

  "flags": {
    "allowGuestDemoWorkspace": true
  },

  "telemetry": {
    "allowedOrigin": ["localhost", "127.0.0.1"],
    "ga4.measurementId": "",
    "ga4.apiSecret": ""
  },

  "metrics": {
    "enabled": false
  },

  "storages": {
    "blob.storage": {
      "provider": "aws-s3",
      "bucket": "gddocs-blobs",
      "config": {
        "endpoint": "http://gddocs_minio:9000",
        "region": "us-east-1",
        "forcePathStyle": true,
        "credentials": {
          "accessKeyId": "${MINIO_ROOT_USER}",
          "secretAccessKey": "${MINIO_ROOT_PASSWORD}"
        }
      }
    },
    "avatar.storage": {
      "provider": "aws-s3",
      "bucket": "gddocs-avatars",
      "config": {
        "endpoint": "http://gddocs_minio:9000",
        "region": "us-east-1",
        "forcePathStyle": true,
        "credentials": {
          "accessKeyId": "${MINIO_ROOT_USER}",
          "secretAccessKey": "${MINIO_ROOT_PASSWORD}"
        }
      }
    }
  },

  "copilot": {
    "storage": {
      "provider": "aws-s3",
      "bucket": "gddocs-copilot",
      "config": {
        "endpoint": "http://gddocs_minio:9000",
        "region": "us-east-1",
        "forcePathStyle": true,
        "credentials": {
          "accessKeyId": "${MINIO_ROOT_USER}",
          "secretAccessKey": "${MINIO_ROOT_PASSWORD}"
        }
      }
    }
  }
}
