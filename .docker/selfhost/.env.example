# ============================================================
#  GD docs — Variables de entorno de ejemplo
#  Copiá este archivo como .env y ajustá los valores.
#  Los scripts install.sh y update.sh generan .env automáticamente.
# ============================================================

# Puerto en que escucha el servidor (expose en el host)
PORT=3010

# ── Rutas de persistencia ─────────────────────────────────
# Cambiá si querés guardar los datos en otra ubicación.
DB_DATA_LOCATION=~/.gddocs/postgres/pgdata
CONFIG_LOCATION=~/.gddocs/config
ASSETS_LOCATION=~/.gddocs/static
REDIS_DATA_LOCATION=~/.gddocs/redis
MINIO_DATA_LOCATION=~/.gddocs/minio

# ── Base de datos (PostgreSQL) ────────────────────────────
DB_USERNAME=gddocs
DB_PASSWORD=
DB_DATABASE=gddocs

# ── MinIO — almacenamiento de objetos ────────────────────
# Usuario y contraseña de la consola MinIO (http://servidor:9001)
# La contraseña debe tener al menos 8 caracteres.
MINIO_ROOT_USER=gddocs
MINIO_ROOT_PASSWORD=

# ── Redis — caché y sesiones ──────────────────────────────
# Contraseña para la autenticación de Redis en la red Docker.
REDIS_PASSWORD=

# ── Rendimiento ───────────────────────────────────────────
NODE_OPTIONS=--max-old-space-size=4096
