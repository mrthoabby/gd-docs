{
  "$schema": "https://github.com/mrthoabby/gd-docs/releases/latest/download/config.schema.json",
  "server": {
    "name": "GD docs Server"
  },
  "auth": {
    "allowSignup": true,
    "allowSignupForOauth": true,
    "requireEmailVerification": false,
    "requireEmailDomainVerification": false,
    "passwordRequirements": {
      "min": 8,
      "max": 128
    },
    "session.ttl": 2592000,
    "session.ttr": 604800
  },
  "storages": {
    "blob.storage": {
      "provider": "aws-s3",
      "bucket": "gddocs-blobs",
      "config": {
        "endpoint": "http://minio:9000",
        "region": "us-east-1",
        "forcePathStyle": true,
        "disablePresign": true,
        "credentials": {
          "accessKeyId": "${MINIO_ROOT_USER}",
          "secretAccessKey": "${MINIO_ROOT_PASSWORD}"
        }
      }
    },
    "avatar.storage": {
      "provider": "aws-s3",
      "bucket": "gddocs-avatars",
      "config": {
        "endpoint": "http://minio:9000",
        "region": "us-east-1",
        "forcePathStyle": true,
        "disablePresign": true,
        "credentials": {
          "accessKeyId": "${MINIO_ROOT_USER}",
          "secretAccessKey": "${MINIO_ROOT_PASSWORD}"
        }
      }
    }
  },
  "copilot": {
    "storage": {
      "provider": "aws-s3",
      "bucket": "gddocs-copilot",
      "config": {
        "endpoint": "http://minio:9000",
        "region": "us-east-1",
        "forcePathStyle": true,
        "disablePresign": true,
        "credentials": {
          "accessKeyId": "${MINIO_ROOT_USER}",
          "secretAccessKey": "${MINIO_ROOT_PASSWORD}"
        }
      }
    }
  }
}
